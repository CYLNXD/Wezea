# ─── CyberHealth Scanner — Variables d'Environnement ─────────────────────────
# Copiez ce fichier en .env et remplissez les valeurs
# Ne commitez JAMAIS le fichier .env dans Git

# ── API ───────────────────────────────────────────────────────────────────────
API_ENV=development                    # development | staging | production
SECRET_KEY=change-me-in-production     # Clé secrète JWT (générez avec: openssl rand -hex 32)
RATE_LIMIT=10/minute                   # Limite de requêtes par IP

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,https://cyberhealth.io

# ── Scanner ───────────────────────────────────────────────────────────────────
SCAN_TIMEOUT_SEC=5                     # Timeout connexion TCP (ports)
DNS_LIFETIME_SEC=8.0                   # Timeout requêtes DNS
SSL_PORT=443                           # Port HTTPS
SSL_EXPIRY_WARNING_DAYS=30             # Alerte si certificat expire dans N jours

# ── Base de données (leads & résultats) ───────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cyberhealth
# DATABASE_URL=sqlite+aiosqlite:///./cyberhealth.db  ← pour le dev local

# ── Email (Lead Gen) ──────────────────────────────────────────────────────────
MAIL_USERNAME=noreply@cyberhealth.io
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=noreply@cyberhealth.io
MAIL_PORT=587
MAIL_SERVER=smtp.sendgrid.net
MAIL_TLS=true

# ── CRM / Webhook ─────────────────────────────────────────────────────────────
CRM_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/xxx/yyy
# ou HubSpot, Pipedrive, Salesforce…

# ── Intégrations optionnelles (enrichissement des scans) ──────────────────────
SHODAN_API_KEY=                        # https://account.shodan.io/
VIRUSTOTAL_API_KEY=                    # https://www.virustotal.com/gui/my-apikey
SECURITYTRAILS_API_KEY=               # https://securitytrails.com/

# ── Redis (cache + queue de jobs PDF) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
